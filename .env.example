# ── AWS ──────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Aurora DSQL Endpoints ───────────────────────────────────────────
# US cluster (required)
DSQL_ENDPOINT_US=your-cluster-endpoint-us-east-1.dsql.aws.com

# EU cluster (optional — uncomment when provisioning a second cluster)
# DSQL_ENDPOINT_EU=your-cluster-endpoint-eu-west-1.dsql.aws.com

# ── Database ────────────────────────────────────────────────────────
DSQL_DATABASE=postgres
DSQL_TOKEN_DURATION_SECS=900